{
  "entities": {
    "User": {
      "title": "User",
      "description": "Thông tin người dùng trong hệ thống",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID duy nhất từ Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Dự án của công ty",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Task": {
      "title": "Task",
      "description": "Công việc cụ thể trong dự án",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assigneeId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status"]
    },
    "AIInteraction": {
      "title": "AIInteraction",
      "description": "Lịch sử tương tác với trợ lý AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "response": { "type": "string" },
        "type": { "type": "string", "enum": ["suggestion", "automation", "summary"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "response"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Thông tin cá nhân người dùng"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Dữ án công ty"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Công việc trong hệ thống"
    },
    "/ai_logs/{logId}": {
      "schema": "AIInteraction",
      "description": "Nhật ký AI"
    }
  }
}
